# Default identity (fallback)
[user]
    name = matzxrr
    email = matzxrr@gmail.com
    signingkey = {{ .gpg_key }}
[commit]
    gpgsign = true
[init]
    defaultBranch = main

{{ if .is_work -}}
# Work identity override
[includeIf "gitdir:~/work/"]
    path = ~/.config/gitconfig/work
{{ end -}}

# Editor / Pager
[core]
    editor = hx
    whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
    pager = diff-so-fancy | less --tabs=4 -RFX
[interactive]
    diffFilter = diff-so-fancy --patch

# Colors
[color]
    ui = true
[color "diff-highlight"]
    oldNormal = red bold
    oldHighlight = red bold 52
    newNormal = green bold
    newHighlight = green bold 22
[color "diff"]
    meta = 11
    frag = magenta bold
    func = 146 bold
    commit = yellow bold
    old = red bold
    new = green bold
    whitespace = red reverse
